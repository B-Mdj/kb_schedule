# production
/build
/frontend/build
/backend/dist

# misc
.DS_Store
*.pem
.git-frontend-backup/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
/frontend/.env
/frontend/.env.local
/frontend/.env.development.local
/frontend/.env.test.local
/frontend/.env.production.local
/backend/.env
/backend/.env.local
/backend/.env.development.local
/backend/.env.test.local
/backend/.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
